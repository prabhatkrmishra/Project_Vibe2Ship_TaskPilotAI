# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ALLOWED_ORIGINS: Comma-separated list of allowed origins for OAuth.
# Replaces APP_URL to support multiple domains (e.g. dev and prod).
# AI Studio automatically injects APP_URL as a fallback at runtime.
ALLOWED_ORIGINS="http://localhost:3000,https://my-app.run.app"
APP_URL="MY_APP_URL"

# -----------------------------------------------------------------------------
# Google OAuth Configuration for Workspace APIs
# -----------------------------------------------------------------------------
# Configure these variables with your Google Cloud Console credentials
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
SESSION_SECRET="your_secure_session_secret"

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGODB_URI="your_mongodb_connection_string"

JWT_SECRET="your_jwt_signing_secret"

