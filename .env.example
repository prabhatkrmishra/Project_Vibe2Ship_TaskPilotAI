# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_gemini_api_key"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# MongoDB Configuration
MONGODB_URI="mongodb_connection_string"
MONGODB_DB="taskpilot-ai"

# Security Configurations
JWT_SECRET="your_jwt_signing_secret"

# Signing key for Drive data backups (HMAC-SHA256).
# Generated with: openssl rand -hex 32
BACKUP_SIGNING_KEY="backup_signing_secret"

# Optional AI Provider Keys
NIM_API_KEY="nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # NVIDIA NIM — build.nvidia.com (1,000 free credits)
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" # 400+ models, ~28 free — openrouter.ai
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"   # Free: 14,400 req/day — console.groq.com
TOGETHER_API_KEY="tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # Open-source models — api.together.ai
DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"   # Cheap reasoning — platform.deepseek.com
MISTRAL_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"    # EU models — console.mistral.ai
CEREBRAS_API_KEY="csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # Fastest inference, 1M tok/day free — cloud.cerebras.ai
FIREWORKS_API_KEY="fw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"   # Production inference — fireworks.ai
